SPOKEN_PAGE_SECRET=replace-this-with-a-long-random-string
SPOKEN_PAGE_ABS_BASE_URL=http://host.docker.internal:13378
# Optional: allow more than one exact ABS base URL instead of locking to one.
# SPOKEN_PAGE_ALLOWED_BASE_URLS=http://host.docker.internal:13378,http://192.168.1.50:13378
# Optional: restores the older less-safe behavior that allows arbitrary entered URLs.
# SPOKEN_PAGE_ALLOW_UNSAFE_CUSTOM_CONNECTIONS=false
